# Admin login secrets. Server-side only.
# UNISORDER_ADMIN_SETUP_KEY is used only for creating the first admin account.
UNISORDER_ADMIN_SETUP_KEY=replace-with-a-long-random-setup-key
UNISORDER_ADMIN_SESSION_SECRET=replace-with-a-long-random-session-secret

# Supabase content store. Server-side only.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
